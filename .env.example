# pondr config — copy to .env and edit
PONDR_LLM_BASE_URL=http://127.0.0.1:9080/v1
PONDR_LLM_API_KEY=local
PONDR_LLM_MODEL=gemma-4-31B-it-Q4_K_M.gguf
PONDR_DASHBOARD_PORT=8090
PONDR_WS_PORT=8765
PONDR_INITIAL_TOPIC=量化交易策略與市場結構研究
# Optional: FRED API key for yield curve poll
FRED_API_KEY=
# Optional Telegram bot for remote chat
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Channel selection (default: ws,stdio; telegram auto if token set)
PONDR_CHANNELS=ws,stdio

# Network bind address. Use 0.0.0.0 to listen on all interfaces (LAN access)
PONDR_BIND_HOST=0.0.0.0  # 預設; 改 127.0.0.1 限本機
